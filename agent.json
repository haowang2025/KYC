{
    "agent_name": "ClearCheck",
    "version": "0.1.0",
    "description": "Merchant risk triage agent — Green / Yellow / Red decisions with evidence",
    "system_prompt": "system_prompt.md",
    "skills": [
        {
            "name": "merchant_risk_triage",
            "path": "skills/merchant_risk_triage/SKILL.md",
            "auto_activate": true,
            "description": "Main triage workflow"
        },
        {
            "name": "kg_entity_lookup",
            "path": "skills/kg_entity_lookup/SKILL.md",
            "auto_activate": false,
            "description": "Entity KG query helper"
        }
    ],
    "tools_required": [
        "web_search",
        "shell_exec"
    ],
    "tools_optional": [
        "arangodb_query",
        "file_read"
    ],
    "agenthansa": {
        "executor_type": "risk-triage",
        "task_schema": {
            "entity_name": {
                "type": "string",
                "required": true
            },
            "country": {
                "type": "string",
                "required": true
            },
            "entity_type": {
                "type": "string",
                "required": false
            },
            "payment_currency": {
                "type": "string",
                "required": false
            },
            "transaction_amount": {
                "type": "number",
                "required": false
            },
            "goods_category": {
                "type": "string",
                "required": false
            },
            "counterparty": {
                "type": "string",
                "required": false
            }
        }
    }
}